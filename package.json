{
  "name": "senda-cms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss,js,jsx,json,md}\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.0.0",
    "@commitlint/config-conventional": "20.0.0",
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.13",
    "@types/node": "20.19.17",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "eslint": "9.36",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.1",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,spec.ts,spec.tsx,test.ts,test.tsx,d.ts}": [
      "eslint --fix"
    ],
    "*.{css,scss,md,json,mdx}": [
      "prettier --write"
    ]
  }
}
