{
  "name": "senda-cms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss,js,jsx,json,md}\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint-staged": "lint-staged",
    "generate-types": "openapi-typescript http://localhost:8000/api/openapi.json -o src/types/api.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-slot": "1.2.3",
    "@tanstack/react-query": "5.90.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jose": "6.1.0",
    "js-cookie": "3.0.5",
    "lucide-react": "0.544.0",
    "next": "15.5.4",
    "openapi-fetch": "0.14.0",
    "openapi-react-query": "0.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.63.0",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.11",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "20.0.0",
    "@commitlint/config-conventional": "20.0.0",
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.13",
    "@tanstack/react-query-devtools": "5.90.2",
    "@types/js-cookie": "3.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20.19.17",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "eslint": "9.36",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.1",
    "openapi-typescript": "7.9.1",
    "prettier": "3.6.2",
    "tailwindcss": "4.1.13",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,spec.ts,spec.tsx,test.ts,test.tsx,d.ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json,mdx}": [
      "prettier --write"
    ]
  }
}
