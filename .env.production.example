# Senda CMS - Production Environment Variables
# Copy this file to your hosting platform's environment configuration
# DO NOT commit actual values to the repository

# ===========================================
# PUBLIC VARIABLES (exposed to browser)
# ===========================================

# Base URL of the backend API
# Example: https://api.senda.com or https://senda-api-xxxxx.run.app
NEXT_PUBLIC_API_BASE_URL=https://your-api-url.com

# Application base URL (optional - hosting platforms often provide this automatically)
# Example: https://senda-cms.vercel.app or https://senda-cms.run.app
NEXT_PUBLIC_APP_BASE_URL=https://your-app-url.com

# Build environment identifier
# Values: "production" | "preview" | "development"
NEXT_PUBLIC_BUILD=production

# ===========================================
# PRIVATE VARIABLES (server-side only)
# ===========================================

# JWT Secret for token validation
# Must match the secret used by the backend API
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
